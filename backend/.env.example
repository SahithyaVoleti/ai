# --- DATABASE CONFIGURATION ---
# For PostgreSQL (Preferred for Production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_interviewer
DB_USER=postgres
DB_PASSWORD=your_password
# Alternatively, use a single connection string:
DATABASE_URL=postgresql://user:password@localhost:5432/ai_interviewer

# For SQLite (Default Fallback)
# No config needed, will use ai_interviewer.db in backend folder

# --- EMAIL SERVICE (BREVO) ---
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=verify@yourdomain.com
BREVO_APP_NAME="AI Interviewer"

# --- PAYMENT GATEWAY (RAZORPAY) ---
RAZORPAY_KEY_ID=rzp_test_your_id
RAZORPAY_KEY_SECRET=your_secret
PAYMENT_TEST_MODE=true

# --- APPLICATION SETTINGS ---
PORT=5000
FLASK_ENV=production
DEBUG=false
